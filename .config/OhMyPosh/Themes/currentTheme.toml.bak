#name of terminal
console_title_template = '{{if .Root}} âڑ،{{end}}{{.Folder | replace "~" "َ±پچ"}} @{{.HostName}}'
version = 3
final_space = true

# --------------------------------------------------------------------
[palette]
  bg = '#232938' 
  fg = '#E5E9F0'
  paths = '#85DAF5'
  pathsFg = '#2A2E41'
  cyan = '#85DAF5'
  gray = '#444b6a'
  blue = '#7EA4F1'
  red = '#EF7680'
  orange = '#ff9e64'
  yellow = '#EFBF78'
  green = '#BADE8D'
  purple = '#B594F0'


[secondary_prompt]
  template = 'ï…¸ '
  foreground = 'p:purple'
  background = 'transparent'

[transient_prompt]
  template = ' â‌¯â‌¯ {{ .AbsolutePWD }} : '
  background = 'transparent'
  foreground_templates = ['{{ if eq .Code 0 }}p:green{{ else }}p:red{{ end }}']
  newline = true

[upgrade]
  source = 'cdn'
  interval = '168h'
  auto = false
  notice = false

[[blocks]]
  type = 'prompt'
  alignment = 'left'

  [[blocks.segments]]
    template = "\nâ•­â”€"
    foreground = 'p:fg'
    type = 'text'
    style = 'plain'

  [[blocks.segments]]
    leading_diamond = 'î‚¶'
    template = '{{ .UserName }}'
    foreground = 'p:paths'
    background = 'p:bg'
    type = 'session'
    style = 'diamond'

  [[blocks.segments]]
    trailing_diamond = 'î‚°'
    template = ' {{.Icon}} '
    foreground = 'p:paths'
    background = 'p:bg'
    type = 'os'
    style = 'diamond'

  [[blocks.segments]]
    leading_diamond = '<transparent,p:paths>î‚°</>'
    trailing_diamond = 'î‚°'
    template = ' {{ .Path }} '
    foreground = 'p:pathsFg'
    background = 'p:paths'
    type = 'path'
    style = 'diamond'

    [blocks.segments.properties]
      folder_icon = '...'
      folder_separator_icon = '<transparent> î‚± </>'
      home_icon = 'َ±‚¶ '
      style = 'agnoster_short'

      [blocks.segments.properties.mapped_locations]
        '~/.config' = 'î—¼ '
        '~/dotfiles' = 'ï’‚ '

  [[blocks.segments]]
    leading_diamond = '<transparent,background>î‚°</>'
    trailing_diamond = 'î‚°'
    template = '<transparent> îھ‡ </> {{ reason .Code }} '
    foreground = 'p:fg'
    background = 'p:red'
    type = 'status'
    style = 'diamond'

[[blocks]]
  type = 'rprompt'
  overflow = 'hidden'

  [[blocks.segments]]
    template = '{{ .FormattedMs }}'
    foreground = 'p:gray'
    type = 'executiontime'
    style = 'plain'

    [blocks.segments.properties]
      style = 'round'
      threshold = 5000

[[blocks]]
  type = 'prompt'
  alignment = 'right'

  [[blocks.segments]]
    leading_diamond = 'î‚¶'
    trailing_diamond = 'î‚´'
    template = 'îœ¥ ({{ url .UpstreamIcon .UpstreamURL }} {{ url .HEAD .UpstreamURL }}){{ if gt .Ahead 0 }}<p:green> +{{ .Ahead }}</>{{ end }}{{ if gt .Behind 0 }}<red> -{{ .Behind }} </>{{ end }}{{ if .Working.Changed }}<p:fg> î¸¼ {{ .Working.String }}</>{{ end }}{{ if .Staging.Changed }}<p:fg> ï…ٹ {{ .Staging.String }}</>{{ end }}'
    foreground = 'p:bg'
    background = 'p:yellow'
    type = 'git'
    style = 'diamond'

    [blocks.segments.properties]
      branch_icon = ''
      cache_duration = 'none'
      display_changing_color = true
      fetch_status = true
      fetch_upstream_icon = true
      full_branch_path = true

  [[blocks.segments]]
    leading_diamond = 'î‚¶'
    trailing_diamond = 'î‚´'
    template = 'îœک {{ .Full }}'
    foreground = 'p:bg'
    background = 'p:green'
    type = 'node'
    style = 'diamond'

  [[blocks.segments]]
    leading_diamond = 'î‚¶'
    trailing_diamond = 'î‚´'
    template = 'îœ‍ {{ .Full }}'
    foreground = 'p:bg'
    background = 'p:red'
    type = 'npm'
    style = 'diamond'

    [blocks.segments.properties]
      display_mode = 'files'
      extensions = ['package-lock.json']

  [[blocks.segments]]
    leading_diamond = 'î‚¶'
    trailing_diamond = 'î‚´'
    template = 'َ°‹پ {{ .Full }}'
    foreground = 'p:bg'
    background = 'p:orange'
    type = 'pnpm'
    style = 'diamond'

    [blocks.segments.properties]
      display_mode = 'files'
      extensions = ['pnpm-lock.yaml']

  [[blocks.segments]]
    leading_diamond = 'î‚¶'
    trailing_diamond = 'î‚´'
    template = 'îœ¼ {{ .Full }}'
    foreground = 'p:bg'
    background = 'p:blue'
    type = 'python'
    style = 'diamond'

    [blocks.segments.properties]
      display_mode = 'files'

  [[blocks.segments]]
    leading_diamond = 'î‚¶'
    trailing_diamond = 'î‚´'
    template = 'îœ¸ {{ .Full }}'
    foreground = 'p:bg'
    background = 'p:red'
    type = 'java'
    style = 'diamond'

  [[blocks.segments]]
    leading_diamond = 'î‚¶'
    trailing_diamond = 'î‚´'
    template = 'îœ½ {{ .Full }}'
    foreground = 'p:bg'
    background = 'p:blue'
    type = 'php'
    style = 'diamond'

[[blocks]]
  type = 'prompt'
  alignment = 'left'
  newline = true

  [[blocks.segments]]
    template = 'â•°â”€ â‌¯â‌¯'
    foreground = 'p:fg'
    type = 'text'
    style = 'diamond'

    [blocks.segments.properties]
      alway_enabled = true
